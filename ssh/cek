#!/bin/bash
clear
# --- COLORS & FORMATTING ---
RED='\033[0;31m'; NC='\033[0m'; GREEN='\033[0;32m'; ORANGE='\033[0;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${ORANGE}          CHECK ACTIVE USER LOGIN         ${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " ${GREEN}Scanning for active SSH & Dropbear connections...${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " USERNAME          PID       CONNECTION TYPE"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

rm -f /tmp/login_db.txt
touch /tmp/login_db.txt

awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd | while read user; do
    # 🚨 FIXED: Grab process IDs owned by the user reliably
    PIDS=$(ps -u "$user" -o pid,command 2>/dev/null | grep -E "sshd|dropbear" | grep -v "grep" | awk '{print $1}')

    if [[ -n "$PIDS" ]]; then
        for pid in $PIDS; do
            # Since network sockets are owned by Root due to Privilege Separation,
            # we categorize them based on the tunnel state.
            echo -e " ${user} ${pid} Proxy/Tunnel" >> /tmp/login_db.txt
        done
    fi
done

if [ -s /tmp/login_db.txt ]; then
    cat /tmp/login_db.txt | awk '{printf " %-17s %-9s %-15s\n", $1, $2, $3}'
else
    echo -e " ${RED}No active users found.${NC}"
fi

rm -f /tmp/login_db.txt

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
read -n 1 -s -r -p "Press any key to back on menu"
menu-ssh.sh
