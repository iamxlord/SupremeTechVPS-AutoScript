#!/bin/bash
clear
RED='\033[0;31m'; NC='\033[0m'; GREEN='\033[0;32m'; ORANGE='\033[0;33m'; BLUE='\033[0;34m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${ORANGE}          DELETE SSH ACCOUNT              ${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

tmp_users="/tmp/ssh_users.txt"
> "$tmp_users"

while IFS=: read -r username password uid gid info home shell; do
    if [[ "$uid" -ge 1000 && "$username" != "nobody" ]]; then
        if [[ "$shell" == "/bin/false" || "$shell" == "/usr/sbin/nologin" || "$shell" == "/bin/true" ]]; then
            exp_raw=$(chage -l "$username" | grep "Account expires" | cut -d: -f2 | sed 's/^ //g')
            if [[ "$exp_raw" == "never" ]]; then exp_display="Lifetime"; else exp_display=$(date -d "$exp_raw" "+%d-%b-%Y" 2>/dev/null); fi
            echo "$username|$exp_display" >> "$tmp_users"
        fi
    fi
done < /etc/passwd

if [[ ! -s "$tmp_users" ]]; then
    echo -e "${RED}Error: No SSH users found!${NC}"
    rm -f "$tmp_users"; sleep 2; menu-ssh.sh; exit 1
fi

echo -e " ${GREEN}[0]  Cancel & Return to Menu${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " NO   USER          EXPIRES"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

i=1
while IFS='|' read -r user exp; do
    printf " %-4s %-13s %-10s\n" "$i." "$user" "$exp"
    ((i++))
done < "$tmp_users"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

read -p " Select Number : " num

# SAFETY CATCH: Trapdoor Exit
if [[ "$num" == "0" ]]; then rm -f "$tmp_users"; menu-ssh.sh; exit 0; fi
if ! [[ "$num" =~ ^[0-9]+$ ]]; then echo -e "${RED}Invalid input! Numbers only.${NC}"; rm -f "$tmp_users"; sleep 1; hapus; exit 1; fi

selected_line=$(sed -n "${num}p" "$tmp_users")
user=$(echo "$selected_line" | cut -d'|' -f1)
exp=$(echo "$selected_line" | cut -d'|' -f2)

if [[ -z "$user" ]]; then echo -e "${RED}Error: Invalid selection.${NC}"; rm -f "$tmp_users"; sleep 1; hapus; exit 1; fi

passwd -l "$user" > /dev/null 2>&1
pkill -u "$user" > /dev/null 2>&1
userdel -f "$user" > /dev/null 2>&1
rm -f /etc/xray/limit/$user
rm -f "$tmp_users"

echo -e "${GREEN}SSH ACCOUNT DELETED SUCCESSFULLY${NC}"
read -n 1 -s -r -p "Press any key to return..."
menu-ssh.sh
