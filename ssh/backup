#!/bin/bash
# --- Mr. X Portable Backup (Telegram Edition) ---

IP=$(curl -sS ifconfig.me)
date=$(date +"%Y-%m-%d")
# Added IP to the filename so you know which server it came from!
Name="Backup-$IP-$date.zip" 

clear
echo -e "\033[0;32m[+] Creating Secure Portable Backup...\033[0m"

# 1. Gather Files Safely (No root passwords!)
mkdir -p /root/backup
> /root/backup/passwd
> /root/backup/shadow

awk -F: '$3 >= 1000 && ($7 == "/bin/false" || $7 == "/usr/sbin/nologin") {print $1}' /etc/passwd | while read user; do
    grep -w "^$user" /etc/passwd >> /root/backup/passwd
    grep -w "^$user" /etc/shadow >> /root/backup/shadow
done

cp -r /etc/xray /root/backup/
cp -r /etc/xray/limit /root/backup/ 2>/dev/null

# 2. Zip Files
cd /root
zip -r $Name backup > /dev/null 2>&1

echo -e "\033[0;33m[+] Processing Upload...\033[0m"

# 3. Check for Telegram Credentials
TG_TOKEN=$(cat /etc/xray/tg_token 2>/dev/null)
TG_CHATID=$(cat /etc/xray/tg_chatid 2>/dev/null)

if [[ -n "$TG_TOKEN" && -n "$TG_CHATID" ]]; then
    echo -e "\033[0;34m[i] Sending directly to your Telegram Bot...\033[0m"
    
    # Format a nice message for the Telegram caption
    caption="📦 *Server Backup*\nIP: \`$IP\`\nDate: \`$date\`\n\n_Auto-generated by Mr. X VPN Manager_"
    
    # Send via Telegram API
    response=$(curl -s -X POST "https://api.telegram.org/bot${TG_TOKEN}/sendDocument" \
        -F chat_id="${TG_CHATID}" \
        -F document="@/root/${Name}" \
        -F caption="${caption}" \
        -F parse_mode="Markdown")
    
    if echo "$response" | grep -q '"ok":true'; then
        echo -e "------------------------------------------------"
        echo -e "\033[0;32m[✔] Success! Backup sent to your Telegram.\033[0m"
        echo -e "------------------------------------------------"
    else
        echo -e "\033[0;31m[✘] Telegram upload failed! Please check your Token/ID.\033[0m"
        TG_FAIL=true
    fi
fi

# 4. Fallback to Cloud Storage if Telegram wasn't set or failed
if [[ -z "$TG_TOKEN" || "$TG_FAIL" == true ]]; then
    echo -e "\033[0;34m[i] Uploading to Cloud Storage...\033[0m"
    link=$(curl -s -F "reqtype=fileupload" -F "fileToUpload=@/root/$Name" https://catbox.moe/user/api.php)
    
    if [[ "$link" != http* ]]; then
        link=$(curl -s -F "file=@/root/$Name" https://file.io | jq -r .link)
    fi
    
    echo -e "------------------------------------------------"
    echo -e "Secure Portable Backup Link:"
    echo -e "\033[0;32m$link\033[0m"
    echo -e "------------------------------------------------"
    echo -e "NOTE: Save this link immediately."
fi

# 5. Cleanup
rm -rf /root/backup
rm -f /root/$Name

read -n 1 -s -r -p "Press any key to return to menu..."
menu
