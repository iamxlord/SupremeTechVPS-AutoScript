#!/bin/bash
clear
# --- COLORS & FORMATTING ---
RED='\033[0;31m'
NC='\033[0m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${ORANGE}      AUTOKILL SETUP (SSH & XRAY)         ${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# [span_0](start_span)Check Current Status[span_0](end_span)
if [[ -f /etc/cron.d/tendang ]]; then
    STATUS="${GREEN}ACTIVE${NC}"
else
    STATUS="${RED}INACTIVE${NC}"
fi

echo -e " Current Status: $STATUS"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " [1]  AutoKill Every 5 Minutes"
echo -e " [2]  AutoKill Every 10 Minutes"
echo -e " [3]  AutoKill Every 15 Minutes"
echo -e " [4]  Turn Off AutoKill"
echo -e " [x]  Back to Menu"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
read -p " Select Option : " req

case $req in
    1)
        # Fires both SSH and Xray multi-login checkers
        echo -e "*/5 * * * * root /usr/bin/tendang\n*/5 * * * * root /usr/bin/xray-limit" > /etc/cron.d/tendang
        echo -e "${GREEN}AutoKill enabled (Every 5 Mins).${NC}"
        [span_1](start_span)service cron restart[span_1](end_span)
        sleep 2
        ;;
    2)
        # Fires both SSH and Xray multi-login checkers
        echo -e "*/10 * * * * root /usr/bin/tendang\n*/10 * * * * root /usr/bin/xray-limit" > /etc/cron.d/tendang
        echo -e "${GREEN}AutoKill enabled (Every 10 Mins).${NC}"
        [span_2](start_span)service cron restart[span_2](end_span)
        sleep 2
        ;;
    3)
        # Fires both SSH and Xray multi-login checkers
        echo -e "*/15 * * * * root /usr/bin/tendang\n*/15 * * * * root /usr/bin/xray-limit" > /etc/cron.d/tendang
        echo -e "${GREEN}AutoKill enabled (Every 15 Mins).${NC}"
        [span_3](start_span)service cron restart[span_3](end_span)
        sleep 2
        ;;
    4)
        [span_4](start_span)rm -f /etc/cron.d/tendang[span_4](end_span)
        [span_5](start_span)echo -e "${RED}AutoKill turned off.${NC}"[span_5](end_span)
        [span_6](start_span)service cron restart[span_6](end_span)
        [span_7](start_span)sleep 2[span_7](end_span)
        ;;
    x)
        [span_8](start_span)menu-ssh.sh[span_8](end_span)
        ;;
    *)
        [span_9](start_span)echo -e "${RED}Invalid Option${NC}"[span_9](end_span)
        [span_10](start_span)sleep 1[span_10](end_span)
        [span_11](start_span)autokill[span_11](end_span)
        ;;
esac
[span_12](start_span)menu-ssh.sh[span_12](end_span)
