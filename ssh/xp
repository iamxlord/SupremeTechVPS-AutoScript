#!/bin/bash
# --- Mr. X Universal Auto-Expiry & JSON Validator ---

CONFIG="/usr/local/etc/xray/config.json"
BACKUP="/tmp/config.json.bak"
today_sec=$(date -d "$(date +%Y-%m-%d)" +%s)

echo "Running Auto-Expiry Check: $(date)" >> /var/log/vpn-expiry.log

# 1. SSH Expiry Check (Preserved)
awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd | while read user; do
    expiration=$(chage -l $user 2>/dev/null | grep "Account expires" | cut -d: -f2 | xargs)
    if [[ "$expiration" != "never" && -n "$expiration" ]]; then
        exp_date_sec=$(date -d "$expiration" +%s 2>/dev/null)
        if [[ -n "$exp_date_sec" && $exp_date_sec -lt $today_sec ]]; then
            echo "Deleted Expired SSH: $user" >> /var/log/vpn-expiry.log
            userdel -f $user 2>/dev/null
            rm -f /etc/xray/limit/$user 2>/dev/null
        fi
    fi
done

# 2. Xray Expiry Check & Hybrid JSON Modification
if [ -f "$CONFIG" ]; then
    # 🚨 Create a safe backup before ANY modifications
    cp "$CONFIG" "$BACKUP"

    grep -E "\/\/ #(##|vl|tr|ss|hy) " "$CONFIG" | while read -r line; do
        tag=$(echo "$line" | awk '{print $2}')
        user=$(echo "$line" | awk '{print $3}')
        exp=$(echo "$line" | awk '{print $4}')
        
        if [[ -n "$exp" ]]; then
            exp_sec=$(date -d "$exp" +%s 2>/dev/null)
            
            if [[ -n "$exp_sec" && $exp_sec -lt $today_sec ]]; then
                echo "Deleted Expired Xray [$tag]: $user" >> /var/log/vpn-expiry.log
                
                # 🚨 Bounded deletion to prevent subset matching (bob vs bob2)
                sed -i "/\"email\": \"$user\"[ \",}]/d" "$CONFIG"
                sed -i "/\/\/ $tag $user /d" "$CONFIG"
                
                # Cleanup limit files
                rm -f /etc/xray/limit/vmess/$user \
                      /etc/xray/limit/vless/$user \
                      /etc/xray/limit/trojan/$user \
                      /etc/xray/limit/shadowsocks/$user \
                      /etc/xray/limit/hysteria/$user 2>/dev/null
            fi
        fi
    done
    
    # 3. Clean trailing commas safely (ONLY at the end of objects)
    sed -i -e '/},$/ { N; /\/\/ #(##|vl|tr|ss|hy|vmess|vless|trojan-ws|ss-ws|hy2)/s/},/}/; P; D; }' "$CONFIG"
    sed -i '/^\s*,\s*$/d' "$CONFIG"

    # 4. 🚨 THE JQ VALIDATOR 🚨
    if command -v jq &> /dev/null; then
        if jq . "$CONFIG" >/dev/null 2>&1; then
            # JSON is perfectly valid. Safe to restart.
            if systemctl is-active xray &>/dev/null; then
                systemctl restart xray
                echo "Xray service restarted after expiry cleanup." >> /var/log/vpn-expiry.log
            fi
        else
            # JSON IS BROKEN. Revert to backup instantly to save the server.
            cp "$BACKUP" "$CONFIG"
            echo "CRITICAL: JSON Corruption prevented. Reverted to backup." >> /var/log/vpn-expiry.log
            systemctl restart xray
        fi
    else
        # Fallback if jq is somehow not installed (should be via setup.sh)
        systemctl restart xray
    fi
else
    echo "Error: Xray config file not found at $CONFIG" >> /var/log/vpn-expiry.log
fi
