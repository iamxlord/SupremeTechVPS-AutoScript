#!/bin/bash
# ==========================================
# RUTHLESS EXPIRY AUTOMATOR (IRON SHIELD VERSION)
# ==========================================

(
    flock -x 200
    
    CONFIG="/usr/local/etc/xray/config.json"
    BACKUP="/tmp/config.json.bak"
    HY_CONFIG="/etc/hysteria/config.yaml"
    HY_EXP="/etc/hysteria/exp.txt"
    
    today_sec=$(date -d "$(date +%Y-%m-%d)" +%s)

    echo "Running Auto-Expiry Check: $(date)" >> /var/log/vpn-expiry.log

    # 1. SSH Expiry Check
    awk -F: '$3 >= 1000 && $1 != "nobody" && ($7 == "/bin/false" || $7 == "/usr/sbin/nologin" || $7 == "/bin/true") {print $1}' /etc/passwd | while read user; do
        
        # 🛡️ THE IRON SHIELD: Double Safety Hardcoded Blacklist
        if [[ "$user" =~ ^(root|daemon|bin|sys|nobody|sshd|nginx|xray|stunnel4|dropbear|proxy|www-data)$ ]]; then
            continue
        fi
        
        expiration=$(chage -l "$user" 2>/dev/null | grep "Account expires" | cut -d: -f2 | xargs)
        if [[ "$expiration" != "never" && -n "$expiration" ]]; then
            exp_date_sec=$(date -d "$expiration" +%s 2>/dev/null)
            
            # If Current Time is past OR EQUAL to Expiry Time
            if [[ -n "$exp_date_sec" && $today_sec -ge $exp_date_sec ]]; then
                echo "Suspended Expired SSH: $user" >> /var/log/vpn-expiry.log
                
                # SURGICAL KILL (Targets ONLY the specific user's tunnels)
                ssh_pids=$(ps auxww | grep -E "sshd: ${user}[@\[ ]" | grep -v grep | awk '{print $2}')
                
                drop_pids=""
                for pid in $(pgrep -x dropbear 2>/dev/null); do
                    if cat /proc/"$pid"/environ 2>/dev/null | tr '\0' '\n' | grep -qE "^(USER|LOGNAME)=${user}$"; then
                        drop_pids="$drop_pids $pid"
                    fi
                done
                drop_ps_pids=$(ps auxww | grep -E "dropbear: ${user}[@\[ ]" | grep -v grep | awk '{print $2}')
                
                ALL_PIDS=$(echo "$ssh_pids $drop_pids $drop_ps_pids" | xargs -n1 | sort -u)
                
                for pid in $ALL_PIDS; do
                    kill -9 "$pid" 2>/dev/null
                done
                
                pkill -u "$user" 2>/dev/null
                killall -u "$user" 2>/dev/null
                
                # Lock the account (Suspends password) without deleting!
                usermod -L "$user" 2>/dev/null
            fi
        fi
    done

    # 2. Xray Expiry Check
    if [ -f "$CONFIG" ]; then
        cp "$CONFIG" "$BACKUP"

        grep -E "\/\/ #(##|vl|tr|ss|re) " "$CONFIG" | while read -r line; do
            tag=$(echo "$line" | awk '{print $2}')
            user=$(echo "$line" | awk '{print $3}')
            exp=$(echo "$line" | awk '{print $4}')
            
            if [[ -n "$exp" ]]; then
                exp_sec=$(date -d "$exp" +%s 2>/dev/null)
                if [[ -n "$exp_sec" && $today_sec -ge $exp_sec ]]; then
                    echo "Deleted Expired Xray [$tag]: $user" >> /var/log/vpn-expiry.log
                    sed -i "/\"email\": \"$user\"[ \",}]/d" "$CONFIG"
                    sed -i "/\/\/ $tag $user /d" "$CONFIG"
                    rm -f /etc/xray/limit/vmess/$user /etc/xray/limit/vless/$user /etc/xray/limit/trojan/$user /etc/xray/limit/shadowsocks/$user 2>/dev/null
                fi
            fi
        done
        
        sed -i -e '/},$/ { N; /\/\/ #(##|vl|tr|ss|re|vmess|vless|trojan-ws|ss-ws|reality)/s/},/}/; P; D; }' "$CONFIG"
        sed -i '/^\s*,\s*$/d' "$CONFIG"

        if command -v jq &> /dev/null; then
            if jq . "$CONFIG" >/dev/null 2>&1; then
                systemctl is-active --quiet xray && systemctl restart xray
            else
                cp "$BACKUP" "$CONFIG"
                echo "CRITICAL: Xray JSON Corruption prevented." >> /var/log/vpn-expiry.log
                systemctl restart xray
            fi
        else
            systemctl restart xray
        fi
    fi

    # 3. Hysteria 2 Expiry Check
    if [ -f "$HY_EXP" ] && [ -f "$HY_CONFIG" ]; then
        while IFS=: read -r hy_user hy_exp; do
            if [[ -n "$hy_exp" ]]; then
                exp_sec=$(date -d "$hy_exp" +%s 2>/dev/null)
                if [[ -n "$exp_sec" && $today_sec -ge $exp_sec ]]; then
                    echo "Deleted Expired Hysteria2: $hy_user" >> /var/log/vpn-expiry.log
                    jq "del(.auth.userpass[\"$hy_user\"])" "$HY_CONFIG" > /tmp/hy.json && mv /tmp/hy.json "$HY_CONFIG"
                    sed -i "/^$hy_user:/d" "$HY_EXP"
                    rm -f /etc/xray/limit/hysteria/$hy_user 2>/dev/null
                    systemctl restart hysteria-server.service
                fi
            fi
        done < "$HY_EXP"
    fi

) 200>/var/lock/xray-expiry.lock
