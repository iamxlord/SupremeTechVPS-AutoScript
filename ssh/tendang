#!/bin/bash
LOG="/var/log/auth.log"
[[ -e "/var/log/secure" ]] && LOG="/var/log/secure"

declare -A user_counts
declare -A user_pids

# 1. DROPBEAR Mapping
cat $LOG | grep -i dropbear | grep -i "Password auth succeeded" > /tmp/login-db.txt
for PID in $(ps aux | grep -i dropbear | grep -v grep | awk '{print $2}'); do
    USER=$(grep "dropbear\[$PID\]" /tmp/login-db.txt | awk '{print $10}' | sed "s/'//g" | tail -1)
    if [[ -n "$USER" ]]; then
        user_counts["$USER"]=$((user_counts["$USER"]+1))
        user_pids["$USER"]="${user_pids[$USER]} $PID"
    fi
done

# 2. OPENSSH Mapping
cat $LOG | grep -i sshd | grep -i "Accepted password for" > /tmp/login-db.txt
for PID in $(ps aux | grep -i sshd | grep -v grep | awk '{print $2}'); do
    USER=$(grep "sshd\[$PID\]" /tmp/login-db.txt | awk '{print $9}' | tail -1)
    if [[ -n "$USER" ]]; then
        user_counts["$USER"]=$((user_counts["$USER"]+1))
        user_pids["$USER"]="${user_pids[$USER]} $PID"
    fi
done

# 3. Enforce Limits & Assasinate
for USER in "${!user_counts[@]}"; do
    if ! id "$USER" &>/dev/null || [[ $(id -u "$USER") -lt 1000 ]]; then continue; fi

    limit=2
    if [[ -f "/etc/xray/limit/$USER" ]]; then limit=$(cat "/etc/xray/limit/$USER"); fi
    count=${user_counts[$USER]}
    
    if [[ $count -gt $limit ]]; then
        date +"%Y-%m-%d %H:%M:%S : Kicked $USER ($count/$limit logins)" >> /var/log/autokill.log
        
        # Kill exact PIDs holding the tunnel open
        for PID in ${user_pids[$USER]}; do
            kill -9 $PID 2>/dev/null
        done
        
        killall -u "$USER" 2>/dev/null
        
        TG_TOKEN=$(cat /etc/xray/tg_token 2>/dev/null)
        TG_CHATID=$(cat /etc/xray/tg_chatid 2>/dev/null)
        if [[ -n "$TG_TOKEN" && -n "$TG_CHATID" ]]; then
            MSG="🚨 *MULTI-LOGIN ALERT* 🚨%0A%0A👤 *User:* \`${USER}\`%0A⚠️ *Logins:* ${count} / ${limit}%0A🛑 *Action:* User connections terminated."
            curl -s "https://api.telegram.org/bot${TG_TOKEN}/sendMessage?chat_id=${TG_CHATID}&text=${MSG}&parse_mode=Markdown" > /dev/null 2>&1
        fi
    fi
done
rm -f /tmp/login-db.txt