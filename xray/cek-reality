#!/bin/bash
clear
# --- COLORS & FORMATTING ---
RED='\033[0;31m'; NC='\033[0m'; GREEN='\033[0;32m'; ORANGE='\033[0;33m'; BLUE='\033[0;34m'

LOG="/var/log/xray/access.log"
CONFIG="/usr/local/etc/xray/config.json"

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${ORANGE}            REALITY USER ACTIVITY                 ${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [[ ! -f "$LOG" ]]; then
    echo -e "${RED} Error: Xray access log not found.${NC}"
    read -n 1 -s -r -p "Press any key..."
    menu-reality.sh; exit 0
fi

echo -e " ${GREEN}TIME      IP ADDRESS       USER${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# 1. Get all active XTLS-Reality users from config
re_users=$(grep -E "// #re " "$CONFIG" | awk '{print $3}')

# 2. Search log for those specific users
found=0
if [[ -n "$re_users" ]]; then
    for user in $re_users; do
        data=$(grep "accepted" "$LOG" | grep "email: $user" | tail -n 5)
        
        if [[ -n "$data" ]]; then
            echo "$data" | awk '{print $2, $4, $NF}' | while read time ip log_user; do
                clean_time=$(echo $time | cut -d. -f1)
                clean_ip=$(echo $ip | cut -d: -f1)
                printf " %-8s %-16s %s\n" "$clean_time" "$clean_ip" "$log_user"
            done
            found=1
        fi
    done
fi

if [[ $found -eq 0 ]]; then
    echo -e " ${ORANGE}No active XTLS-Reality connections found.${NC}"
fi

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
read -n 1 -s -r -p "Press any key to back on menu"
menu-reality.sh
