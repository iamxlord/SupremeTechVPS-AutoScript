#!/bin/bash
# ==========================================
# SupremeTech Xray Multi-Login Enforcer
# ==========================================

# 🚨 Wrap in a File Lock to prevent overlapping cron executions
(
    flock -n 200 || exit 1

    CONFIG="/usr/local/etc/xray/config.json"
    BACKUP="/tmp/config.json.bak"
    LOG_FILE="/var/log/xray/access.log"
    TMP_LOG="/tmp/xray-access.log"
    SUSPEND_DB="/etc/xray/suspended.txt"
    
    # Ensure suspend database exists
    touch "$SUSPEND_DB"

    # 1. SECURE THE LOGS (Snapshot & Reset)
    # We copy the log to analyze it, then empty the real log so the next 5-minute window is fresh
    if [[ -f "$LOG_FILE" ]]; then
        cp "$LOG_FILE" "$TMP_LOG"
        echo "" > "$LOG_FILE"
    else
        exit 0
    fi

    MODIFIED=0

    # --- TELEGRAM ALERT FUNCTION ---
    send_tg_alert() {
        local user=$1
        local proto=$2
        local ip_count=$3
        local limit=$4
        
        TG_TOKEN=$(cat /etc/xray/tg_token 2>/dev/null)
        TG_CHATID=$(cat /etc/xray/tg_chatid 2>/dev/null)

        if [[ -n "$TG_TOKEN" && -n "$TG_CHATID" ]]; then
            MSG="🚨 *MULTI-LOGIN SUSPENSION* 🚨%0A%0A👤 *User:* \`${user}\`%0A🔌 *Protocol:* \`${proto}\`%0A⚠️ *IPs Detected:* ${ip_count} / ${limit}%0A🛑 *Action:* Account Suspended from Config!"
            curl -s "https://api.telegram.org/bot${TG_TOKEN}/sendMessage?chat_id=${TG_CHATID}&text=${MSG}&parse_mode=Markdown" > /dev/null 2>&1
        fi
    }

    # --- SUSPENSION ENGINE ---
    suspend_user() {
        local user=$1
        local tag=$2
        local proto=$3
        local ip_count=$4
        local limit=$5

        echo "$(date +"%Y-%m-%d %H:%M:%S") : SUSPENDED $user | Protocol: $proto | IPs: $ip_count/$limit" >> /var/log/autokill.log
        echo "$proto:$user:$(date +"%Y-%m-%d")" >> "$SUSPEND_DB"

        # Extract Expiry Date to match the exact string
        local exp=$(grep -E "\\/\\/ $tag " "$CONFIG" | grep "$user" | awk '{print $4}' | head -n 1)

        # SAFE TEXT-BASED DELETION (From our bulletproof del-* scripts)
        sed -i "/\/\/ $tag $user $exp/d" "$CONFIG"
        sed -i "/\"email\": \"$user\"/d" "$CONFIG"
        sed -i '/^\s*$/d' "$CONFIG"
        sed -i '/^\s*,\s*$/d' "$CONFIG"
        sed -i -z 's/}\s*{/},\n          {/g' "$CONFIG"

        send_tg_alert "$user" "$proto" "$ip_count" "$limit"
        MODIFIED=1
    }

    # ==========================================
    # 2. XRAY PROTOCOL SCANNER
    # ==========================================
    cp "$CONFIG" "$BACKUP"

    # Scan VMess (Tag: ###)
    for user in $(grep -E "// ### " "$CONFIG" | awk '{print $3}'); do
        if [[ -f "/etc/xray/limit/vmess/$user" ]]; then
            limit=$(cat "/etc/xray/limit/vmess/$user")
            # Extract unique IPs from the log for this user
            ip_count=$(grep "accepted" "$TMP_LOG" | grep "email: $user" | awk '{print $3}' | cut -d: -f1 | sort | uniq | wc -l)
            if [[ $ip_count -gt $limit ]]; then
                suspend_user "$user" "###" "VMess" "$ip_count" "$limit"
            fi
        fi
    done

    # Scan VLESS (Tag: #vl)
    for user in $(grep -E "// #vl " "$CONFIG" | awk '{print $3}'); do
        if [[ -f "/etc/xray/limit/vless/$user" ]]; then
            limit=$(cat "/etc/xray/limit/vless/$user")
            ip_count=$(grep "accepted" "$TMP_LOG" | grep "email: $user" | awk '{print $3}' | cut -d: -f1 | sort | uniq | wc -l)
            if [[ $ip_count -gt $limit ]]; then
                suspend_user "$user" "#vl" "VLESS" "$ip_count" "$limit"
            fi
        fi
    done

    # Scan Trojan (Tag: #tr)
    for user in $(grep -E "// #tr " "$CONFIG" | awk '{print $3}'); do
        if [[ -f "/etc/xray/limit/trojan/$user" ]]; then
            limit=$(cat "/etc/xray/limit/trojan/$user")
            ip_count=$(grep "accepted" "$TMP_LOG" | grep "email: $user" | awk '{print $3}' | cut -d: -f1 | sort | uniq | wc -l)
            if [[ $ip_count -gt $limit ]]; then
                suspend_user "$user" "#tr" "Trojan" "$ip_count" "$limit"
            fi
        fi
    done

    # Scan Shadowsocks (Tag: #ss)
    for user in $(grep -E "// #ss " "$CONFIG" | awk '{print $3}'); do
        if [[ -f "/etc/xray/limit/shadowsocks/$user" ]]; then
            limit=$(cat "/etc/xray/limit/shadowsocks/$user")
            ip_count=$(grep "accepted" "$TMP_LOG" | grep "email: $user" | awk '{print $3}' | cut -d: -f1 | sort | uniq | wc -l)
            if [[ $ip_count -gt $limit ]]; then
                suspend_user "$user" "#ss" "Shadowsocks" "$ip_count" "$limit"
            fi
        fi
    done

    # ==========================================
    # 3. HYSTERIA 2 PROTOCOL SCANNER (Standalone)
    # ==========================================
    HY_CONFIG="/etc/hysteria/config.yaml"
    HY_EXP="/etc/hysteria/exp.txt"
    HY_MODIFIED=0

    if [[ -f "$HY_EXP" ]]; then
        for user in $(awk -F: '{print $1}' "$HY_EXP"); do
            if [[ -f "/etc/xray/limit/hysteria/$user" ]]; then
                limit=$(cat "/etc/xray/limit/hysteria/$user")
                # Hysteria2 logs to systemd. We pull the last 5 minutes of auths.
                ip_count=$(journalctl -u hysteria-server --since "5 minutes ago" --no-pager | grep "authenticated" | grep "auth=$user" | awk -F"remoteAddr=" '{print $2}' | awk '{print $1}' | cut -d: -f1 | sort | uniq | wc -l)
                
                if [[ $ip_count -gt $limit ]]; then
                    echo "$(date +"%Y-%m-%d %H:%M:%S") : SUSPENDED $user | Protocol: Hysteria2 | IPs: $ip_count/$limit" >> /var/log/autokill.log
                    echo "Hysteria2:$user:$(date +"%Y-%m-%d")" >> "$SUSPEND_DB"
                    
                    # Safe JQ Deletion
                    jq "del(.auth.userpass[\"$user\"])" "$HY_CONFIG" > /tmp/hy.json && mv /tmp/hy.json "$HY_CONFIG"
                    sed -i "/^$user:/d" "$HY_EXP"
                    
                    send_tg_alert "$user" "Hysteria2" "$ip_count" "$limit"
                    HY_MODIFIED=1
                fi
            fi
        done
        
        if [[ $HY_MODIFIED -eq 1 ]]; then
            systemctl restart hysteria-server.service
        fi
    fi

    # ==========================================
    # 4. STRICT JSON VALIDATION & HEALING
    # ==========================================
    if [[ $MODIFIED -eq 1 ]]; then
        if command -v jq &> /dev/null; then
            if jq empty "$CONFIG" >/dev/null 2>&1; then
                systemctl restart xray
            else
                echo "CRITICAL: Xray Multi-Login JSON Corruption prevented. Restoring backup." >> /var/log/autokill.log
                cp "$BACKUP" "$CONFIG"
                systemctl restart xray
            fi
        else
            systemctl restart xray
        fi
    fi

    rm -f "$TMP_LOG"
    rm -f "$BACKUP"

) 200>/var/lock/xray-limit.lock
