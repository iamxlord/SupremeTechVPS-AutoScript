#!/bin/bash
clear
CONFIG="/usr/local/etc/xray/config.json"
domain=$(cat /etc/xray/domain)
PBK=$(cat /etc/xray/reality_public)
SID=$(cat /etc/xray/reality_shortid)

# --- COLORS & FORMATTING ---
RED='\033[0;31m'
NC='\033[0m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
BLUE='\033[0;34m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${ORANGE}        CREATE XTLS-REALITY ACCOUNT       ${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# 1. GET USER INPUT
while true; do
    read -p " Username   : " user
    if [[ -z "$user" ]]; then
        echo -e "${RED}Error: Username cannot be empty!${NC}"
    elif [[ ! "$user" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        echo -e "${RED}Error: Username can only contain letters, numbers, hyphens, and underscores!${NC}"
    elif grep -q "\"email\": \"$user\"" "$CONFIG"; then
        echo -e "${RED}Error: User '$user' already exists! Try another.${NC}"
    else
        break
    fi
done

read -p " Expired (Days): " masaaktif
[[ -z "$masaaktif" ]] && masaaktif=30

read -p " Max Login     : " limit
[[ -z "$limit" ]] && limit=2

read -p " Spoofed SNI (e.g. bug.com) : " sni
[[ -z "$sni" ]] && sni="www.microsoft.com"

# 2. PROCESS DATA
uuid=$(cat /proc/sys/kernel/random/uuid)
exp=$(date -d "$masaaktif days" +"%Y-%m-%d")
exp_display=$(date -d "$masaaktif days" +"%b %d, %Y")

# 3. INJECT USER (TARGETING // #reality)
sed -i "s|// #reality|,\\
          { \"id\": \"$uuid\", \"flow\": \"xtls-rprx-vision\", \"email\": \"$user\" }\\
          // #reality\\
          // #re $user $exp|g" $CONFIG

# Set Limit File
mkdir -p /etc/xray/limit/vless
echo "$limit" > /etc/xray/limit/vless/$user

# Restart Xray
systemctl restart xray

# 4. GENERATE LINK
reality_link="vless://${uuid}@${domain}:443?security=reality&encryption=none&pbk=${PBK}&headerType=none&fp=chrome&type=tcp&flow=xtls-rprx-vision&sni=${sni}&sid=${SID}#${user}"

# 5. SHOW OUTPUT
clear
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${ORANGE}        XTLS-REALITY ACCOUNT CREATED      ${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " Username    : ${GREEN}${user}${NC}"
echo -e " Domain      : ${GREEN}${domain}${NC}"
echo -e " Spoofed SNI : ${GREEN}${sni}${NC}"
echo -e " User ID     : ${GREEN}${uuid}${NC}"
echo -e " Expired On  : ${GREEN}${exp_display}${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${ORANGE} LINK REALITY:${NC}"
echo -e "${GREEN}${reality_link}${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
read -n 1 -s -r -p "Press any key to back on menu"
